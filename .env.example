# =============================================================================
# .env.example — Binance Futures Trading Bot
# =============================================================================
#
# Copy this file to .env and fill in your Futures Testnet API credentials.
#
#   cp .env.example .env
#
# How to get credentials:
#   1. Go to https://testnet.binancefuture.com
#   2. Log in (GitHub OAuth)
#   3. Navigate to "API Key" section
#   4. Click "Generate Key" — copy both values below
#
# WARNING: Never commit your real .env file to version control!
# =============================================================================

BINANCE_API_KEY=your_futures_testnet_api_key_here
BINANCE_API_SECRET=your_futures_testnet_api_secret_here
